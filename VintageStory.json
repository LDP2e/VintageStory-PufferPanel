{
  "name": "VintageStory Server",
  "display": "VintageStory",
  "type": "vintagestory-dotNert",
  "install": [
    {
      "files": [
        "https://cdn.vintagestory.at/gamefiles/stable/vs_server_linux-x64_${version}.tar.gz",
        "https://builds.dotnet.microsoft.com/dotnet/aspnetcore/Runtime/${dotNet}/aspnetcore-runtime-${dotNet}-linux-x64.tar.gz"
      ],
      "type": "download"
    },
    {
      "commands": [
        "mkdir vintagestory",
        "tar --no-same-owner -xzvf vs_server_linux-x64_${version}.tar.gz -C vintagestory",
        "rm vs_server_linux-x64_${version}.tar.gz",
        "echo 'installing .NET 8'",
        "mkdir dotnet",
        "tar -xf aspnetcore-runtime-${dotNet}-linux-x64.tar.gz -C dotnet",
        "rm aspnetcore-runtime-${dotNet}-linux-x64.tar.gz",
        "mkdir data"
      ],
      "type": "command"
    }
  ],
  "run": {
    "stop": "/stop",
    "command": "./vintagestory/VintagestoryServer --dataPath data",
    "workingDirectory": "",
    "pre": [],
    "post": [],
    "environmentVars": {
      "DOTNET_ROOT": "dotnet"
    }
  },
  "data": {
    "dotNet": {
      "type": "string",
      "desc": ".NET 8 ASP.NET Core Runtime version. Default is latest stable patch. Change only if you know what you're doing.",
      "display": ".NET Version",
      "required": true,
      "value": "8.0.26"
    },
    "version": {
      "type": "string",
      "desc": "Vintage Story stable version (e.g. 1.21.6). See https://www.vintagestory.at/selfhosting/",
      "display": "Version",
      "required": true,
      "value": "1.21.6"
    }
  },
  "supportedEnvironments": [
    {
      "type": "standard"
    }
  ],
  "requirements": {}
}
